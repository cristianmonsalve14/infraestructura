@startuml
skinparam rectangle {
  Shadowing false
  BackgroundColor<<Gateway>> #F9E79F
  BackgroundColor<<Auth>> #AED6F1
  BackgroundColor<<Academic>> #A9DFBF
  BackgroundColor<<Attendance>> #F5B7B1
  BorderColor black
}
skinparam databaseBackgroundColor #FAD7A0
skinparam databaseBorderColor #B9770E
skinparam noteBackgroundColor #FCF3CF
skinparam noteBorderColor #B7950B

actor "Frontend (Web / Móvil)" as FE

rectangle "API Gateway\n(Spring Cloud Gateway)" <<Gateway>> as GW

rectangle "auth-service\n(Autenticación / Usuarios)" <<Auth>> as AUTH
rectangle "academic-service\n(Gestión Académica)" <<Academic>> as ACADEMIC
rectangle "attendance-service\n(Asistencia y Anotaciones)" <<Attendance>> as ATTEND

database "PostgreSQL (BD única)" as DB

FE --> GW : "HTTP + JWT"

GW --> AUTH : "/auth/* (validación JWT)"
GW --> ACADEMIC : "REST API (JSON)"
GW --> ATTEND : "REST API (JSON)"

ACADEMIC --> DB : "Lectura / Escritura\n(tablas académicas)"
ATTEND --> DB : "Lectura / Escritura\n(tablas de asistencia)"
AUTH --> DB : "Lectura / Escritura\n(tablas de usuarios y roles)"

note right of GW
  <b>Gateway:</b> enrutamiento, validación JWT, rate-limit, CORS
end note

note left of ACADEMIC
  <b>Patrones aplicados:</b>\n- Repository (Spring Data JPA)\n- Factory Method (DTO -> Entidad)\n- Circuit Breaker (Resilience4j) para llamadas externas
end note

note bottom of DB
  <b>Decisión:</b> BD única (PostgreSQL) por fase inicial.\nOwnership lógico: cada servicio gestiona sus tablas.\nRecomendación: migrar a DB por servicio en fases posteriores.
end note

@enduml
